APP_PORT=8000

DJANGO_SETTINGS_MODULE=config.settings
DATABASE_URL=postgis://route_fuel:route_fuel@db:5432/route_fuel
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

POSTGRES_DB=route_fuel
POSTGRES_USER=route_fuel
POSTGRES_PASSWORD=route_fuel
POSTGRES_PORT=5432
POSTGRES_SHARED_BUFFERS=128MB
POSTGRES_WORK_MEM=8MB
POSTGRES_MAINTENANCE_WORK_MEM=64MB
POSTGRES_MAX_CONNECTIONS=40
POSTGRES_EFFECTIVE_CACHE_SIZE=512MB
POSTGRES_SHM_SIZE=128mb
POSTGRES_MEMORY_LIMIT=768m
POSTGRES_CPUS=1.0

REDIS_PORT=6379
REDIS_MAX_MEMORY=128mb
REDIS_MEMORY_LIMIT=192m
REDIS_CPUS=0.25

WEB_MEMORY_LIMIT=768m
WEB_CPUS=1.0

CELERY_MEMORY_LIMIT=512m
CELERY_CPUS=0.75
CELERY_CONCURRENCY=1
CELERY_LOG_LEVEL=info

GRANIAN_HOST=0.0.0.0
GRANIAN_PORT=8000
GRANIAN_WORKERS=1
GRANIAN_BLOCKING_THREADS=4
GRANIAN_BACKPRESSURE=16
GRANIAN_ACCESS_LOG=false
GRANIAN_LOG_LEVEL=info

OPENROUTESERVICE_API_KEY=your-open-api-key
OPENROUTESERVICE_BASE_URL=https://api.openrouteservice.org
OPENROUTESERVICE_PROFILE=driving-car